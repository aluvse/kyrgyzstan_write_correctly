{
    "manifest_version": 3,
    "name": "Kyrgyzstan: Write Correctly",
    "version": "1.0.1",
    "permissions": ["storage", "tabs"],
    "action": {
        "default_popup": "popup.html",
        "default_icon": "icon.svg"
    },
    "background": {
        "scripts": ["background.js"]
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "kyrgyzstan-fixer@dev.aluvse.gmail.com",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "include_user_data": false,
                "telemetry": false,
                "required": ["none"]
            }
        }
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "css": ["style.css"],
            "run_at": "document_end"
        }
    ]
}
